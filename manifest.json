{
  "manifest_version": 3,
  "name": "Prompt Engine",
  "version": "1.0",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": ["activeTab", "storage"],

  "host_permissions": [
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*"
      ],
      "js": [
        "popup/ui.js",
        "popup/api.js",
        "popup/sidebar.js",
        "popup/cards.js",
        "popup/popup.js",
        "popup/inject.js"
      ],
      "css": ["styles/style.css"]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["data/*.json"],
      "matches": ["<all_urls>"]
    }
  ]
}